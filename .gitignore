# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build output
node_modules
dist
dist-ssr
*.local

# TypeScript incremental build outputs (created by tsc -b during pnpm build)
*.tsbuildinfo
# tsc -b emits .d.ts/.js for root config files (vite.config.ts) — don't commit
vite.config.d.ts
vite.config.js

# Tauri / Rust build artifacts
/target/
/src-tauri/target/
src-tauri/target/
/src-tauri/gen/schemas

# Portable runtime data (created by 01c at runtime; never committed)
/data/
/data-dev/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local Claude Code / agent tooling state — not part of the project
.claude/
.superpowers/
.playwright-mcp/
.tmp/
# Ad-hoc screenshots from local UI verification runs
/hakoniwa-*.png
/screenshot-*.png
